<Window x:Class="HardwareMonitor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HardwareMonitor.ViewModels"
        xmlns:conv="clr-namespace:HardwareMonitor.Converters"
        Title="Hardware Monitor" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <conv:BytesToMBConverter x:Key="BytesToMB" />
        <conv:BytesToGBConverter x:Key="BytesToGB" />
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель с кнопками -->
        <StackPanel Orientation="Horizontal" Grid.Row="0">
            <Button Content="Обновить" Width="120" Height="35" Command="{Binding RefreshCommand}" Background="#2563EB" Foreground="White"/>
            <Button Content="Экспорт TXT" Width="120" Height="35" Margin="10,0,0,0" Command="{Binding ExportTxtCommand}" Background="#10B981" Foreground="White"/>
            <Button Content="Экспорт CSV" Width="120" Height="35" Margin="10,0,0,0" Command="{Binding ExportCsvCommand}" Background="#F59E0B" Foreground="White"/>
            <Button Content="Экспорт JSON" Width="120" Height="35" Margin="10,0,0,0" Command="{Binding ExportJsonCommand}" Background="#3B82F6" Foreground="White"/>
        </StackPanel>

        <!-- Вкладки -->
        <TabControl Grid.Row="1" Margin="0,10,0,0">
            <!-- Вкладка Процессор -->
            <TabItem Header="Процессор">
                <ScrollViewer>
                    <StackPanel Margin="10">
                        <TextBlock Text="Название:" FontWeight="Bold"/>
                        <TextBlock Text="{Binding CpuInfo.Name}" Margin="0,0,0,10"/>

                        <TextBlock Text="Производитель:" FontWeight="Bold"/>
                        <TextBlock Text="{Binding CpuInfo.Manufacturer}" Margin="0,0,0,10"/>

                        <TextBlock Text="Архитектура:" FontWeight="Bold"/>
                        <TextBlock Text="{Binding CpuInfo.Architecture}" Margin="0,0,0,10"/>

                        <TextBlock Text="Ядер:" FontWeight="Bold"/>
                        <TextBlock Text="{Binding CpuInfo.CoreCount}" Margin="0,0,0,10"/>

                        <TextBlock Text="Потоков:" FontWeight="Bold"/>
                        <TextBlock Text="{Binding CpuInfo.ThreadCount}" Margin="0,0,0,10"/>

                        <TextBlock Text="Базовая частота (МГц):" FontWeight="Bold"/>
                        <TextBlock Text="{Binding CpuInfo.BaseFrequency}" Margin="0,0,0,10"/>

                        <TextBlock Text="Загрузка:" FontWeight="Bold"/>
                        <ProgressBar Value="{Binding CpuInfo.LoadPercentage}" Maximum="100" Height="20" Margin="0,5,0,5"/>
                        <TextBlock Text="{Binding CpuInfo.LoadPercentage, StringFormat={}{0:F1}%}" 
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Вкладка Память -->
            <TabItem Header="Память">
                <ScrollViewer>
                    <StackPanel Margin="10">
                        <TextBlock Text="Общий объём (МБ):" FontWeight="Bold"/>
                        <TextBlock Text="{Binding MemoryInfo.TotalMemoryBytes, Converter={StaticResource BytesToMB}}" Margin="0,0,0,10"/>

                        <TextBlock Text="Доступно (МБ):" FontWeight="Bold"/>
                        <TextBlock Text="{Binding MemoryInfo.AvailableMemoryBytes, Converter={StaticResource BytesToMB}}" Margin="0,0,0,10"/>

                        <TextBlock Text="Использовано:" FontWeight="Bold"/>
                        <ProgressBar Value="{Binding MemoryInfo.UsagePercentage, Mode=OneWay}" Maximum="100" Height="20" Margin="0,5,0,5"/>
                        <TextBlock Text="{Binding MemoryInfo.UsagePercentage, StringFormat={}{0:F1}%}" HorizontalAlignment="Center"/>

                        <TextBlock Text="Модули памяти:" FontWeight="Bold" Margin="0,10,0,5"/>
                        <ItemsControl ItemsSource="{Binding MemoryInfo.Modules}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="Gray" BorderThickness="0,0,0,1" Padding="3" Margin="0,2">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Manufacturer}" FontWeight="SemiBold"/>
                                            <TextBlock>Объём: <Run Text="{Binding CapacityBytes, Converter={StaticResource BytesToMB}}"/> МБ</TextBlock>
                                            <TextBlock>Скорость: <Run Text="{Binding SpeedMHz}"/> МГц</TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Вкладка Диски -->
            <TabItem Header="Диски">
                <ScrollViewer>
                    <StackPanel Margin="10">
                        <TextBlock Text="Физические диски:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <ItemsControl ItemsSource="{Binding DiskInfo.PhysicalDisks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <TextBlock Text="{Binding Model}" Width="200"/>
                                        <TextBlock Text="{Binding SizeBytes, Converter={StaticResource BytesToGB}}" Width="80"/>
                                        <TextBlock Text="ГБ" Width="30"/>
                                        <TextBlock Text="{Binding MediaType}" Width="100"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Логические диски:" FontWeight="Bold" Margin="0,10,0,5"/>
                        <ItemsControl ItemsSource="{Binding DiskInfo.LogicalDisks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <TextBlock Text="{Binding DriveLetter}" Width="50"/>
                                        <TextBlock Text="{Binding TotalSizeBytes, Converter={StaticResource BytesToGB}}" Width="80"/>
                                        <TextBlock Text="ГБ всего" Width="70"/>
                                        <TextBlock Text="{Binding FreeSizeBytes, Converter={StaticResource BytesToGB}}" Width="80"/>
                                        <TextBlock Text="ГБ своб" Width="70"/>
                                        <TextBlock Text="{Binding UsagePercent, StringFormat={}{0:F1}%}" Width="60"/>
                                        <TextBlock Text="{Binding FileSystem}" Width="80"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Вкладка Видеокарта -->
            <TabItem Header="Видеокарта">
                <StackPanel Margin="10">
                    <TextBlock Text="Название:" FontWeight="Bold"/>
                    <TextBlock Text="{Binding VideoInfo.Name}" Margin="0,0,0,10"/>

                    <TextBlock Text="Объём памяти (МБ):" FontWeight="Bold"/>
                    <TextBlock Text="{Binding VideoInfo.VideoMemoryBytes, Converter={StaticResource BytesToMB}}" Margin="0,0,0,10"/>

                    <TextBlock Text="Версия драйвера:" FontWeight="Bold"/>
                    <TextBlock Text="{Binding VideoInfo.DriverVersion}" Margin="0,0,0,10"/>

                    <TextBlock Text="Разрешение:" FontWeight="Bold"/>
                    <TextBlock Text="{Binding VideoInfo.VideoModeDescription}" Margin="0,0,0,10"/>

                    <TextBlock Text="Частота (Гц):" FontWeight="Bold"/>
                    <TextBlock Text="{Binding VideoInfo.CurrentRefreshRate}" Margin="0,0,0,10"/>
                </StackPanel>
            </TabItem>

            <!-- Вкладка Сеть -->
            <TabItem Header="Сеть">
                <ScrollViewer>
                    <StackPanel Margin="10">
                        <ItemsControl ItemsSource="{Binding NetworkAdapters}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="Gray" BorderThickness="0,0,0,1" Padding="5" Margin="0,2">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                            <TextBlock>MAC: <Run Text="{Binding MacAddress}"/></TextBlock>
                                            <TextBlock>Подключен: <Run Text="{Binding IsConnected}"/></TextBlock>
                                            <TextBlock>Скорость (Мбит/с): <Run Text="{Binding SpeedBitsPerSec, StringFormat={}{0:N0}}"/></TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Вкладка Система -->
            <TabItem Header="Система">
                <StackPanel Margin="10">
                    <TextBlock Text="ОС:" FontWeight="Bold"/>
                    <TextBlock Text="{Binding SystemInfo.OsName}" Margin="0,0,0,10"/>

                    <TextBlock Text="Версия:" FontWeight="Bold"/>
                    <TextBlock Text="{Binding SystemInfo.OsVersion}" Margin="0,0,0,10"/>

                    <TextBlock Text="Архитектура:" FontWeight="Bold"/>
                    <TextBlock Text="{Binding SystemInfo.Architecture}" Margin="0,0,0,10"/>

                    <TextBlock Text="Имя компьютера:" FontWeight="Bold"/>
                    <TextBlock Text="{Binding SystemInfo.ComputerName}" Margin="0,0,0,10"/>

                    <TextBlock Text="Пользователь:" FontWeight="Bold"/>
                    <TextBlock Text="{Binding SystemInfo.UserName}" Margin="0,0,0,10"/>
                </StackPanel>
            </TabItem>

            <!-- Вкладка Процессы -->
            <TabItem Header="Процессы">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid ItemsSource="{Binding Processes}" SelectedItem="{Binding SelectedProcess}"
                              AutoGenerateColumns="False" IsReadOnly="True" Grid.Row="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="200"/>
                            <DataGridTextColumn Header="Состояние" Binding="{Binding Status}" Width="100"/>
                            <DataGridTextColumn Header="CPU %" Binding="{Binding CpuUsage, StringFormat={}{0:F1}}" Width="80"/>
                            <DataGridTextColumn Header="Память (МБ)" Binding="{Binding MemoryMB, StringFormat={}{0:F1}}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button Content="Снять задачу" Command="{Binding KillProcessCommand}"
                            Width="120" Height="30" Margin="5" HorizontalAlignment="Left" Grid.Row="1"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>